# ═══════════════════════════════════════════════════════════════════════════════
# Kisaan AI - Production Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy these to your Railway/Render dashboard under "Environment Variables"

# ── Required: AI Services ──────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENWEATHERMAP_API_KEY=your_openweather_api_key_here

# ── Required: Authentication ───────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters

# ── Required: Backend URL (set AFTER first deployment) ────────────────────────
# Railway example: https://kisaan-ai-production.up.railway.app
# Render example: https://kisaan-ai-backend.onrender.com
VITE_API_URL=https://your-backend-url-here

# ── Optional: Database Path (for custom persistent storage) ───────────────────
# Railway: Leave unset (uses /app/kisaan_ai.db with volume)
# Render: Set to /var/data/kisaan_ai.db (configured in render.yaml)
# DATABASE_PATH=/var/data/kisaan_ai.db

# ── Optional: Firebase (for push notifications) ───────────────────────────────
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
